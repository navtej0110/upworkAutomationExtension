generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id         String   @id @default(cuid())
  name       String
  title      String
  skills     String
  hourlyRate Float?
  bio        String?
  experience String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Job {
  id              String   @id @default(cuid())
  upworkId        String   @unique
  title           String
  description     String
  category        String?
  budget          String?
  link            String
  publishedAt     DateTime?
  skills          String?
  matchScore      Float?
  matchReason     String?
  status          String   @default("new")
  proposals       String?
  jobType         String?
  experienceLevel String?
  duration        String?
  weeklyHours     String?
  clientCountry   String?
  clientSpent     String?
  clientVerified  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
