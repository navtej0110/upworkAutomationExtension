{
  "manifest_version": 3,
  "name": "Upwork Job Scraper",
  "version": "1.0",
  "description": "Scrapes Upwork jobs and sends them to your dashboard",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://www.upwork.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["content.js"]
    }
  ]
}
